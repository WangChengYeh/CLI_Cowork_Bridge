#!/usr/bin/env python3
"""
ccb (Claude Code Bridge) - Unified AI Launcher
Supports Claude + Codex / Claude + Gemini / all three simultaneously
Uses tmux as the project UI backend
"""

import sys
import os
from pathlib import Path

script_dir = Path(__file__).resolve().parent
sys.path.insert(0, str(script_dir / "lib"))
from stdio_runtime import setup_windows_encoding
from terminal_runtime.backend_env import get_backend_env
from cli.entrypoint import run_cli_entrypoint
from cli.imessage_cli import run_imessage_cli
from cli.room_cli import run_room_cli

setup_windows_encoding()

backend_env = get_backend_env()
if backend_env and not os.environ.get("CCB_BACKEND_ENV"):
    os.environ["CCB_BACKEND_ENV"] = backend_env

VERSION = "6.0.29"
GIT_COMMIT = "30a2c7f"
GIT_DATE = "2026-05-07"


def main():
    argv = sys.argv[1:]

    if argv and argv[0] == "room":
        return run_room_cli(
            argv[1:],
            project_root=Path.cwd(),
            stdout=sys.stdout,
            stderr=sys.stderr,
        )

    if argv and argv[0] == "imessage":
        return run_imessage_cli(
            argv[1:],
            project_root=Path.cwd(),
            stdout=sys.stdout,
            stderr=sys.stderr,
        )

    return run_cli_entrypoint(
        argv,
        version=VERSION,
        script_root=script_dir,
        cwd=Path.cwd(),
        stdout=sys.stdout,
        stderr=sys.stderr,
    )


if __name__ == "__main__":
    sys.exit(main())
